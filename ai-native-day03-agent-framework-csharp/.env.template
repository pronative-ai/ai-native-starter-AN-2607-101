# ProNative AI Day 3 — Environment Variables Template
# Copy this file to .env and fill in your values.
# .env is gitignored — do not commit secrets.

# Shared (used by all labs via Day03TrainingConfig)
BATCH_ID=AN-XXXX-XXX
STUDENT_ID=ST-XXXX-XXXX
AZURE_AI_PROJECT_ENDPOINT=https://your-project.endpoint.azure.com/api/projects/your-project
PROJECT_ENDPOINT=https://your-project.endpoint.azure.com/api/projects/your-project
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5-mini
FOUNDRY_AGENT_NAME=your-agent-name

# Lab05, Lab07 — Azure OpenAI endpoint
AZURE_OPENAI_ENDPOINT=https://your-openai-endpoint.azure.com
AZURE_AI_FOUNDRY_OPENAI_ENDPOINT=https://your-foundry-openai-endpoint.azure.com

# Lab06 — Hybrid RAG (Azure AI Search)
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_INDEX_NAME=idx-your-student-rag
AZURE_SEARCH_ADMIN_KEY=
HYBRID_RAG_RETRIEVAL_MODE=azure-ai-search-text
HYBRID_RAG_TOP=3

# Cosmos DB Configuration
COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-account-key
COSMOS_DATABASE=your-database-name

# Lab 04 — Session Checkpoints
COSMOS_SESSION_CONTAINER=agent-session-checkpoints
ENABLE_COSMOS_PERSISTENCE=true
COSMOS_CREATE_IF_NOT_EXISTS=true

# Lab 06 — Hybrid RAG Knowledge
COSMOS_CONTAINER=training-knowledge
COSMOS_SEED_SAMPLE_DATA=true
