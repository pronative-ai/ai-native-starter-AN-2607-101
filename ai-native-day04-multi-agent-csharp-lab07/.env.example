# ============================================================
# ProNative AI - Day 04 Multi-Agent Training Environment
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# ---- Shared Training Identity (Labs 01-03, 06-07) ----
BATCH_ID=your-batch-id
STUDENT_ID=your-student-id
PN_BATCH_ID=your-batch-id
PN_STUDENT_ID=your-student-id

# ---- Azure AI Foundry Connection (Labs 01-03) ----
AZURE_AI_PROJECT_ENDPOINT=https://your-project.endpoint.ai.azure.com/
PROJECT_ENDPOINT=https://your-project.endpoint.ai.azure.com/
AZURE_OPENAI_CHAT_DEPLOYMENT=your-model-deployment

# ---- Magentic Orchestration (Lab 02) ----
MAGENTIC_REQUIRE_PLAN_SIGNOFF=false
MAGENTIC_MAX_ROUNDS=4
MAGENTIC_MAX_RESETS=1
MAGENTIC_MAX_STALLS=1

# ---- A2A Agent Exposure (Lab 03) ----
A2A_PATH=/a2a/your-path

# ---- Agent Gateway (Labs 06-07) ----
PN_AGENTGATEWAY_LIVE=true
PN_AGENTGATEWAY_BEARER_TOKEN=
PN_AGENTGATEWAY_API_KEY=
PN_AGENTGATEWAY_ENDPOINT=https://your-agentgateway.azurecontainerapps.io
PN_AGENTGATEWAY_ROUTE=agents/your-route
PN_AGENTGATEWAY_MODEL_PATH=/azure/v1/chat/completions
PN_AGENTGATEWAY_FAILURE_PATH=/not-configured/your-lab

# ---- Lab / Cost Tracking (Labs 06-07) ----
PN_LAB_ID=day04-lab06
PN_COST_CENTER=ProNative-AI-Native-Training

# ---- Azure Foundry Resources (Lab 06) ----
PN_FOUNDRY_RESOURCE_NAME=your-resource-name
PN_FOUNDRY_PROJECT_NAME=your-project-name
PN_MODEL_DEPLOYMENT=gpt-5-mini

# ---- MCP / A2A Backend Hosts (Lab 06) ----
PN_MCP_BACKEND_HOST=https://your-mcp-host.azurecontainerapps.io/mcp
PN_A2A_BACKEND_HOST=your-a2a-host.azurecontainerapps.io:443

# ---- OpenTelemetry (Labs 06-07) ----
PN_OTLP_ENDPOINT=http://localhost:4317

# ---- Rate Limiting (Lab 07) ----
PN_RATE_LIMIT_BURST_COUNT=8

# ---- Training Ops API Key (Lab 05 - UTCP placeholder) ----
PRONATIVE_TRAINING_OPS_API_KEY=
