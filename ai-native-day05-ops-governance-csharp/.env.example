# ──────────────────────────────────────────────────────
# Shared / Batch identity
# ──────────────────────────────────────────────────────
BATCH_ID=AN-2607-101
STUDENT_ID=ST-2606-1000
ENVIRONMENT_ID=an2607101
COST_CENTER=Training
OWNER=pronative-ai

# ──────────────────────────────────────────────────────
# Azure OpenAI / Foundry  (Lab01, Lab02, Lab03)
# ──────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://proj-an2607101-default-resource.openai.azure.com/openai/v1
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BEARER_TOKEN=

# ──────────────────────────────────────────────────────
# AgentGateway on AKS  (Lab03)
# ──────────────────────────────────────────────────────
AGENTGATEWAY_ENDPOINT=https://aks-an2607101-agw-dns-xywyud9k.hcp.centralindia.azmk8s.io
AGENTGATEWAY_ROUTE=/openai/v1/chat/completions
AGENTGATEWAY_API_KEY=
AGENTGATEWAY_BEARER_TOKEN=
AGENTGATEWAY_BODY=

# ──────────────────────────────────────────────────────
# AgentGateway MCP endpoint (Lab08)
# ──────────────────────────────────────────────────────
AGENTGATEWAY_MCP_ENDPOINT=http://localhost:3000

# ──────────────────────────────────────────────────────
# Azure Monitor / Log Analytics  (Lab01, Lab04, Lab07)
# ──────────────────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=
LOG_ANALYTICS_WORKSPACE_ID=

# ──────────────────────────────────────────────────────
# Azure Cost Management  (Lab04)
# ──────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=
EVIDENCE_LOOKBACK_DAYS=7

# ──────────────────────────────────────────────────────
# Runpod vLLM Neocloud  (Lab06)
# ──────────────────────────────────────────────────────
RUNPOD_ENDPOINT_ID=
RUNPOD_API_KEY=
RUNPOD_MODEL=
RUNPOD_OPENAI_BASE_URL=
RUNPOD_PROMPT=

# ──────────────────────────────────────────────────────
# Foundry Local CPU  (Lab05)
# ──────────────────────────────────────────────────────
FOUNDRY_LOCAL_MODEL_ALIAS=qwen2.5-0.5b

# ──────────────────────────────────────────────────────
# Local Foundry endpoint for AgentGateway
# ──────────────────────────────────────────────────────
LOCAL_FOUNDRY_BASE_URL=http://host.docker.internal:11434/v1

# ──────────────────────────────────────────────────────
# Custom prompts  (optional overrides)
# ──────────────────────────────────────────────────────
LAB02_PROMPT=

# ──────────────────────────────────────────────────────
# Langfuse  (LLM observability)
# ──────────────────────────────────────────────────────
# 1. Open http://localhost:3001 and create an admin account
# 2. Create a project, then go to Settings → API Keys
# 3. Create a key pair and base64-encode it:
#    echo -n "pk-lf-...:sk-lf-..." | base64
# 4. Paste the base64 string below
LANGFUSE_AUTH_HEADER=
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=http://localhost:3001
LANGFUSE_MCP_ACCESS_TOKEN=
