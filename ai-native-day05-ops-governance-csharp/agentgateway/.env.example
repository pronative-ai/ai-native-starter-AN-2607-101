# ──────────────────────────────────────────────────────
# Azure OpenAI (upstream LLM provider)
# ──────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_RESOURCE_NAME=proj-an2607101-default-resource

# ──────────────────────────────────────────────────────
# Local Foundry endpoint (optional)
# ──────────────────────────────────────────────────────
LOCAL_FOUNDRY_BASE_URL=http://host.docker.internal:11434/v1

# ──────────────────────────────────────────────────────
# AgentGateway virtual API key (client auth)
# ──────────────────────────────────────────────────────
AGENTGATEWAY_API_KEY=

# ──────────────────────────────────────────────────────
# Langfuse OTLP export auth (base64-encoded pk:sk pair)
# ──────────────────────────────────────────────────────
LANGFUSE_AUTH_HEADER=

# ──────────────────────────────────────────────────────
# Langfuse secrets
# ──────────────────────────────────────────────────────
NEXTAUTH_SECRET=changeme-generate-with-openssl-rand-hex-32
NEXTAUTH_URL=http://localhost:3001
SALT=changeme-generate-with-openssl-rand-hex-32
ENCRYPTION_KEY=changeme-generate-with-openssl-rand-hex-32

# ──────────────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres

# ──────────────────────────────────────────────────────
# ClickHouse
# ──────────────────────────────────────────────────────
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=clickhouse

# ──────────────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────────────
REDIS_PASSWORD=myredissecret

# ──────────────────────────────────────────────────────
# MinIO object storage
# ──────────────────────────────────────────────────────
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=miniosecret
